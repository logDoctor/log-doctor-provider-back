# Log Doctor Backend - 환경 변수 설정 샘플

# --- 인증 설정 ---
# AUTH_METHOD: "managed_identity" (로컬 CLI 또는 운영 환경 Managed Identity) 또는 "secret" (전통적인 시크릿 방식)
AUTH_METHOD=managed_identity

# Azure AD (Entra ID) 설정
# AUTH_METHOD="secret"인 경우 필수 입력
# "managed_identity" 사용 시에도 로컬에서 특정 테넌트를 타겟팅할 때 입력을 권장합니다.
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret-only-if-method-is-secret
TENANT_ID=your-tenant-id

# --- 데이터베이스 설정 ---
COSMOS_ENDPOINT=https://log-doctor.documents.azure.com:443/
COSMOS_DATABASE=log-doctor-db

# --- 개발 설정 ---
# Uvicorn 포트 (기본값: 8000)
# PORT=8000

# .env 파일 내부에 추가 또는 수정
# Teams 앱 로컬 테스트 시 ngrok이나 dev tunnel을 쓰신다면 그 주소도 나중에 여기에 추가해 주시면 됩니다!
BACKEND_CORS_ORIGINS=[]