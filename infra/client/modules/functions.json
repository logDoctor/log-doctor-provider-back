        "scriptContent": "      param([string]$ProviderUrl, [string]$TenantId, [string]$SubscriptionId, [string]$AgentId, [string]$AgentVersion)\n      $HandshakeUrl = \"${ProviderUrl}/api/v1/agents/handshake\"\n      $Body = @{\n        tenant_id = $TenantId\n        subscription_id = $SubscriptionId\n        agent_id = $AgentId\n        agent_version = $AgentVersion\n      } | ConvertTo-Json\n\n      Write-Output \"Sending Handshake to: $HandshakeUrl\"\n      try {\n        Invoke-RestMethod -Uri $HandshakeUrl -Method Post -Body $Body -ContentType \"application/json\"\n        Write-Output \"Handshake Successful\"\n      } catch {\n        Write-Error \"Handshake Failed: $_\"\n      }\n    ",
        "retentionInterval": "P1D",
        "cleanupPreference": "OnSuccess"
      },
