        "[resourceId('Microsoft.ManagedIdentity/userAssignedIdentities', format('{0}-script-id', parameters('functionAppName')))]",
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ]
    }
